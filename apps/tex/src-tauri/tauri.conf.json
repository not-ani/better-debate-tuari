{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tex",
  "version": "0.0.2",
  "identifier": "com.ani.tex",
  "build": {
    "beforeDevCommand": "bun run --cwd ../../packages/tex-ui-solid dev -- --host 0.0.0.0 --port 1422",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run --cwd ../../packages/tex-ui-solid build",
    "frontendDist": "../../../packages/tex-ui-solid/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tex",
        "width": 1460,
        "height": 980
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
