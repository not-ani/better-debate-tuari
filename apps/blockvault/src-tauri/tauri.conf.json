{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlockVault",
  "version": "0.1.0",
  "identifier": "com.ani.blockvault",
  "build": {
    "beforeDevCommand": "bun run --cwd ../../packages/ui-solid dev -- --host 0.0.0.0 --port 1421",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "bun run --cwd ../../packages/ui-solid build",
    "frontendDist": "../../../packages/ui-solid/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BlockVault",
        "width": 1440,
        "height": 960
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
